    "sharedRules": [
      {
        "name": "MOVE",
        "id": "98bc-8e1e-e591-23d6",
        "hidden": false,
        "description": "Units may move spaces equal to their MV value\nwhen they MOVE",
        "publicationId": "da35-e534-5d09-746b",
        "page": "13"
      },
      {
        "name": "Step",
        "id": "c017-2f16-4d88-8c6b",
        "hidden": false,
        "description": "Move the specified number of spaces. Does not count as a MOVE.",
        "publicationId": "da35-e534-5d09-746b",
        "page": "62"
      },
      {
        "name": "Push",
        "id": "e400-17e1-4374-0dcb",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "Forcibly push unit a number of spaces, as long as each space of the push is further away from the pushing unit or effect than the last space. Does not count as a MOVE."
      },
      {
        "name": "Pull",
        "id": "f53b-1470-2340-5632",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "Forcibly pull unit a number of spaces, as long as each space of the pull is closer to the pulling unit or effect than the last space. Does not count as a MOVE."
      },
      {
        "name": "Free Movement",
        "id": "1599-bc10-aa0f-1796",
        "hidden": false,
        "page": "62",
        "publicationId": "da35-e534-5d09-746b",
        "description": "Unit’s movement cannot be reduced by any means."
      },
      {
        "name": "PHYS",
        "id": "fe9c-d30f-faaa-0283",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "14",
        "description": "Take 1 less damage from type that is NOT fire, toxic, curse and holy."
      },
      {
        "name": "SUPER",
        "id": "348c-1744-4051-838d",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "14",
        "description": "Take 1 less damage from any damage."
      },
      {
        "name": "MAG",
        "id": "48c2-8b2c-923c-7eaa",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "14",
        "description": "Take 1 less damage from fire, toxic, curse and holy type damage."
      },
      {
        "name": "Melee",
        "id": "01be-6619-763c-0b95",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "16",
        "description": "Melee abilities can only target adjacent characters."
      },
      {
        "name": "Ranged",
        "id": "0c94-bcaa-a6ec-6810",
        "hidden": false,
        "description": "Range can be measured in any direction, including diagonally. Abilities have a minimum range of 1 by default, but may have a higher minimum range (range 2-4, for example, meaning adjacent characters or spaces cannot be targeted).",
        "publicationId": "da35-e534-5d09-746b",
        "page": "18"
      },
      {
        "name": "Devil Damage",
        "id": "97d6-91a3-5f58-6d45",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "18",
        "description": "Cannot be reduced, increased, or ignored for any reason. Additionally units reduced to 0 hp by devil damage are instantly obliterated"
      },
      {
        "name": "Vitality",
        "id": "f187-e53c-c368-071c",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "18",
        "description": "Take -1 damage, discard one after taking damage. Cancels Vulnerable."
      },
