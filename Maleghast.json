    "sharedRules": [
      {
        "name": "MOVE",
        "id": "98bc-8e1e-e591-23d6",
        "hidden": false,
        "description": "Units may move spaces equal to their MV value\nwhen they MOVE",
        "publicationId": "da35-e534-5d09-746b",
        "page": "13"
      },
      {
        "name": "Step",
        "id": "c017-2f16-4d88-8c6b",
        "hidden": false,
        "description": "When a unit steps, it moves that many spaces, but it doesn’t count as a MOVE.",
        "publicationId": "da35-e534-5d09-746b",
        "page": "13"
      },
      {
        "name": "Push",
        "id": "e400-17e1-4374-0dcb",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "13",
        "description": "When a unit is pushed by an ability, it is called forced movement. Forced movement ignores movement penalties (such as from terrain) and doesn’t count as a MOVE or step."
      },
      {
        "name": "Pull",
        "id": "f53b-1470-2340-5632",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "13",
        "description": "When a unit is pulled by an ability, it is called forced movement. Forced movement ignores movement penalties (such as from terrain) and doesn’t count as a MOVE or step."
      },
      {
        "name": "Free Movement",
        "id": "1599-bc10-aa0f-1796",
        "hidden": false,
        "page": "13",
        "publicationId": "da35-e534-5d09-746b",
        "description": "Free movement means a unit’s movement can’t be reduced by any means"
      },
      {
        "name": "Physical Armor",
        "id": "fe9c-d30f-faaa-0283",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "14",
        "description": "Take 1 less damage from type that is NOT fire, toxic, curse and holy."
      },
      {
        "name": "Super Armor",
        "id": "348c-1744-4051-838d",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "14",
        "description": "Take 1 less damage from any damage."
      },
      {
        "name": "Magical Armor",
        "id": "48c2-8b2c-923c-7eaa",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "14",
        "description": "Take 1 less damage from fire, toxic, curse and holy type damage."
      },
      {
        "name": "Melee",
        "id": "01be-6619-763c-0b95",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "16",
        "description": "Melee abilities can only target adjacent characters."
      },
      {
        "name": "Ranged",
        "id": "0c94-bcaa-a6ec-6810",
        "hidden": false,
        "description": "Range can be measured in any direction, including diagonally. Abilities have a minimum range of 1 by default, but may have a higher minimum range (range 2-4, for example, meaning adjacent characters or spaces cannot be targeted).",
        "publicationId": "da35-e534-5d09-746b",
        "page": "18"
      },
      {
        "name": "Devil Damage",
        "id": "97d6-91a3-5f58-6d45",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "18",
        "description": "Devil damage cannot be reduced, increased, or ignored for any reason. Additionally units reduced to 0 hp by devil damage are instantly obliterated"
      },
      {
        "name": "New Rule",
        "id": "4bf8-266e-8c98-6107",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "18",
        "description": "Piercing damage ignores armor. It otherwise keeps its damage type."
      },
      {
        "name": "Vitality",
        "id": "f187-e53c-c368-071c",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "18",
        "description": "Take -1 damage, discard one after taking damage."
      },
