      {
        "name": "Speed",
        "id": "0ca2-ff44-6777-335a",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "18",
        "description": "MOVE +2 more spaces, discard one after MOVEing. Cancels Slow."
      },
      {
        "name": "Slow",
        "id": "0d13-dca4-d672-7825",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "18",
        "description": "MOVE a max of 1 space, discard one after MOVEing. Cancels Speed."
      },
      {
        "name": "Adverse",
        "id": "65d3-6afb-4579-e343",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "Special terrain type, like mud, rubble, water, etc. Costs +1 more movement to exit."
      },
      {
        "name": "Armor",
        "id": "09e0-8180-75eb-0964",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "Armor blocks 1 damage any time it is applied, depending on type."
      },
      {
        "name": "Hazard",
        "id": "29f7-4151-a515-b088",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "Special terrain type. A unit that starts their turn in a hazard takes 1 damage, ignoring armor, and a unit also takes this damage if they enter a hazard space during their turn. Hazards can overlap other terrain types."
      },
      {
        "name": "Charge",
        "id": "7825-7d1a-3bb7-c43a",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "Cannot be used round 1."
      },
      {
        "name": "Curseproof",
        "id": "6949-df60-4ad5-266d",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "Immune to damage and effects of Curses from foes."
      },
      {
        "name": "Elevation",
        "id": "adcb-5e0a-15b8-40f4",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "Special terrain type. Provides cover. Costs +1 movement to enter from a non-elevated space. Units on elevation gain +1D on attacks against units not on elevation, and units gain -1D to attack units on elevation if they are on ground level."
      },
      {
        "name": "Damage",
        "id": "d0df-bd18-8252-fa0c",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "All damage is physical (un-typed), magical (toxic, curse, fire, holy), or devil."
      },
      {
        "name": "Line",
        "id": "169d-d625-cf2a-6dc8",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "Affects all units in a line. Lines can only be drawn in orthogonal (compass) directions and can only be drawn from one of those spaces."
      },
      {
        "name": "Large",
        "id": "1758-6282-af7b-2d65",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "This unit is 2x2. It ignores elevated spaces and cannot take cover. It is affected by terrain and other space-based effects as long as their occupy at least one space of their total area, but these effects don’t stack on them."
      },
      {
        "name": "Obliterate",
        "id": "300a-06fd-038a-9e02",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "A unit that is obliterated leaves neither body nor SOUL and does not trigger effects that trigger when they are slain or reduced to 0 hp."
      },
      {
        "name": "Pierce",
        "id": "5f34-028e-546c-634c",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "This damage ignores armor"
      },
      {
        "name": "Soulless",
        "id": "dd58-6f92-81f8-9ed7",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "A soulless unit leaves no corpse, doesn’t grant SOUL, and can’t be used for body block."
      },
      {
        "name": "Splash",
        "id": "854b-b098-5061-6a50",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "Affects all adjacent units, but not the target. Can be splash (target) or splash (self)."
      },
      {
        "name": "Summon",
        "id": "2247-175f-d327-0b2b",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "Summoned units are usually created by abilities. When summoning a unit, place it on the battlefield in a free space in range. Summoning a unit doesn’t count as it moving or entering a space. Summoned units are SOULLESS and may be activated in the round after their summoning."
      },
      {
        "name": "Wall",
        "id": "5f25-fc5a-8bda-ec1b",
        "hidden": false,
        "publicationId": "da35-e534-5d09-746b",
        "page": "62",
        "description": "Terrain type. Blocks movement and line of sight. Can be targeted and destroyed as a character but does not trigger effects, and has 2 hp."
      },
      {
        "name": "Token",
        "id": "52aa-183d-215e-51f0",
        "hidden": false,
        "alias": [
          "Tokens"
        ],
        "description": "Tokens apply a static effect while a unit has at least one. Mutation tokens may be discarded in place of any other token, ie they can be a stand-in and act as a ‘copy’ for any other token, allowing you to keep the original."
      },
      {
        "name": "Corpse",
        "id": "a55b-b0e2-9a4f-96d6",
        "hidden": false,
        "description": "When a unit dies, it leaves a corpse marker. Multiple corpses can stack in one location. Corpses can be created by other means."
      }
    ],
